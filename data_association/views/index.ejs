<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <h3 class="text-3xl md-5">Create Account</h3>
        <form action="/register" method="POST" class="flex flex-col gap-3 mt-5 w-full md:w-1/2">
            <input class="px-3 py-2 rounded-md  outline-none bg-transparent border-2 border-blue-zinc-800" type="text" name="username" placeholder="Username">
            <input class="px-3 py-2 rounded-md  outline-none bg-transparent border-2 border-blue-zinc-800" type="text" name="name" placeholder="Name">
            <input class="px-3 py-2 rounded-md  outline-none bg-transparent border-2 border-blue-zinc-800" type="number" name="age" placeholder="Age">
            <input class="px-3 py-2 rounded-md  outline-none bg-transparent border-2 border-blue-zinc-800" type="email" name="email" placeholder="Email">
            <input class="px-3 py-2 rounded-md  outline-none bg-transparent border-2 border-blue-zinc-800" type="password" name="password" placeholder="Password">
            <input class="px-5 py-2 rounded-md bg-blue-500 text-white" type="Submit" value="Create Account"> 
        </form> "
    </div>
</body>
</html>